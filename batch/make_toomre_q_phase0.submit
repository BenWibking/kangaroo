#!/bin/bash
#SBATCH -t 05:00:00
#SBATCH -A ast236
#SBATCH -N 1
#SBATCH -p batch
#SBATCH -J kangaroo-toomre-p0
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=32

set -euo pipefail

module load gcc/14.2.0

: "${PLOTFILE:=/lustre/orion/ast236/proj-shared/wibking/noCGM_0.1uG/Phase0}"
: "${OUTPUT_DIR:=toomre_q_noCGM_0.1uG_Phase0}"
: "${R_MIN_KPC:=0.0}"
: "${R_MAX_KPC:=17.5}"
: "${DR_KPC:=0.25}"
: "${Z_MAX_KPC:=1.0}"
: "${GAMMA:=1.6666666666666667}"
: "${OVERWRITE:=1}"

: "${KANGAROO_EXECUTOR_MODE:=streaming}"
: "${KANGAROO_EXECUTOR_MAX_ACTIVE_TASKS_PER_LOCALITY:=128}"
: "${KANGAROO_PLOTFILE_READ_CONCURRENCY:=16}"
: "${KANGAROO_EXECUTOR_MAX_ACTIVE_STORAGE_UNITS_PER_LOCALITY:=64}"
: "${KANGAROO_EXECUTOR_MAX_INPUT_BYTES_PER_LOCALITY:=64G}"
: "${KANGAROO_EXECUTOR_MAX_OUTPUT_BYTES_PER_LOCALITY:=2G}"
: "${KANGAROO_PLOTFILE_READ_MAX_BYTES_IN_FLIGHT:=64G}"
: "${KANGAROO_PLOTFILE_IO_POOL:=plotfile_io}"
: "${KANGAROO_PLOTFILE_IO_POOL_THREADS:=16}"
: "${KANGAROO_PLOTFILE_ZERO_COPY_READS:=1}"
export KANGAROO_EXECUTOR_MODE
export KANGAROO_EXECUTOR_MAX_ACTIVE_TASKS_PER_LOCALITY
export KANGAROO_EXECUTOR_MAX_ACTIVE_STORAGE_UNITS_PER_LOCALITY
export KANGAROO_EXECUTOR_MAX_INPUT_BYTES_PER_LOCALITY
export KANGAROO_EXECUTOR_MAX_OUTPUT_BYTES_PER_LOCALITY
export KANGAROO_PLOTFILE_READ_MAX_BYTES_IN_FLIGHT
export KANGAROO_PLOTFILE_READ_CONCURRENCY
export KANGAROO_PLOTFILE_IO_POOL
export KANGAROO_PLOTFILE_IO_POOL_THREADS
export KANGAROO_PLOTFILE_ZERO_COPY_READS

PROGRESS_ARGS=()
if [[ "${KANGAROO_PROGRESS:-1}" == "1" ]]; then
  PROGRESS_ARGS+=(--progress)
fi

OVERWRITE_ARGS=()
if [[ "$OVERWRITE" == "1" ]]; then
  OVERWRITE_ARGS+=(--overwrite)
fi

if [[ -n "${KANGAROO_EVENT_LOG:-}" ]]; then
  mkdir -p event_logs
  if [[ "$KANGAROO_EVENT_LOG" == "1" || "$KANGAROO_EVENT_LOG" == "auto" ]]; then
    KANGAROO_EVENT_LOG="$PWD/event_logs/toomre_q.${SLURM_JOB_ID:-manual}.events.jsonl"
  fi
  export KANGAROO_EVENT_LOG
fi

export PYTHONUNBUFFERED=1
export OMP_NUM_THREADS=1

export SPACK_HPX_PREFIX="$(spack location -i 'hpx@1.11.0 networking=mpi %gcc@14.2.0')"
export SPACK_MPI_PREFIX="$(spack location -i 'openmpi%gcc@14.2.0')"
export LD_LIBRARY_PATH="$SPACK_HPX_PREFIX/lib64:$SPACK_HPX_PREFIX/lib:$SPACK_MPI_PREFIX/lib64:$SPACK_MPI_PREFIX/lib:${LD_LIBRARY_PATH:-}"

NNODES="${SLURM_NNODES:-4}"
CPUS_PER_TASK="${SLURM_CPUS_PER_TASK:-32}"
if [[ "${SLURM_TRES_PER_TASK:-}" =~ (^|,)cpu=([0-9]+)(,|$) ]]; then
  CPUS_PER_TASK="${BASH_REMATCH[2]}"
  if [[ "${SLURM_CPUS_PER_TASK:-}" != "$CPUS_PER_TASK" ]]; then
    echo "Normalizing SLURM_CPUS_PER_TASK=${SLURM_CPUS_PER_TASK:-unset} to SLURM_TRES_PER_TASK cpu=${CPUS_PER_TASK}"
  fi
  export SLURM_CPUS_PER_TASK="$CPUS_PER_TASK"
fi

HPX_GUARD_PAGE_ARG=--hpx:ini=hpx.stacks.use_guard_pages=0
export HPXRUN_ARGS="${HPXRUN_ARGS:+${HPXRUN_ARGS} }${HPX_GUARD_PAGE_ARG}"

date
echo "host=$(hostname)"
echo "SLURM_JOB_ID=${SLURM_JOB_ID:-manual}"
echo "NNODES=${NNODES}"
echo "CPUS_PER_TASK=${CPUS_PER_TASK}"
echo "SPACK_HPX_PREFIX=${SPACK_HPX_PREFIX}"
echo "SPACK_MPI_PREFIX=${SPACK_MPI_PREFIX}"
echo "HPXRUN_ARGS=${HPXRUN_ARGS}"
echo "KANGAROO_EXECUTOR_MODE=${KANGAROO_EXECUTOR_MODE}"
echo "KANGAROO_EXECUTOR_MAX_ACTIVE_TASKS_PER_LOCALITY=${KANGAROO_EXECUTOR_MAX_ACTIVE_TASKS_PER_LOCALITY}"
echo "KANGAROO_EXECUTOR_MAX_ACTIVE_STORAGE_UNITS_PER_LOCALITY=${KANGAROO_EXECUTOR_MAX_ACTIVE_STORAGE_UNITS_PER_LOCALITY}"
echo "KANGAROO_EXECUTOR_MAX_INPUT_BYTES_PER_LOCALITY=${KANGAROO_EXECUTOR_MAX_INPUT_BYTES_PER_LOCALITY}"
echo "KANGAROO_EXECUTOR_MAX_OUTPUT_BYTES_PER_LOCALITY=${KANGAROO_EXECUTOR_MAX_OUTPUT_BYTES_PER_LOCALITY}"
echo "KANGAROO_PLOTFILE_READ_CONCURRENCY=${KANGAROO_PLOTFILE_READ_CONCURRENCY}"
echo "KANGAROO_PLOTFILE_READ_MAX_BYTES_IN_FLIGHT=${KANGAROO_PLOTFILE_READ_MAX_BYTES_IN_FLIGHT}"
echo "KANGAROO_PLOTFILE_IO_POOL=${KANGAROO_PLOTFILE_IO_POOL}"
echo "KANGAROO_PLOTFILE_IO_POOL_THREADS=${KANGAROO_PLOTFILE_IO_POOL_THREADS}"
echo "KANGAROO_PLOTFILE_ZERO_COPY_READS=${KANGAROO_PLOTFILE_ZERO_COPY_READS}"
echo "KANGAROO_EVENT_LOG=${KANGAROO_EVENT_LOG:-disabled}"
echo "plotfile=${PLOTFILE}"
echo "output_dir=${OUTPUT_DIR}"
echo "r_min_kpc=${R_MIN_KPC}"
echo "r_max_kpc=${R_MAX_KPC}"
echo "dr_kpc=${DR_KPC}"
echo "z_max_kpc=${Z_MAX_KPC}"
echo "gamma=${GAMMA}"
echo "overwrite=${OVERWRITE}"

"$PWD/scripts/utils/hpxrun_spack_hpx.sh" \
  -r srun \
  -p mpi \
  -l "$NNODES" \
  -t "$CPUS_PER_TASK" \
  "$PWD/.pixi/envs/spack-hpx/bin/python" \
  "$PWD/scripts/plotfile_toomre_q.py" \
  -- \
  "$PLOTFILE" \
  --output-dir "$OUTPUT_DIR" \
  --r-min-kpc "$R_MIN_KPC" \
  --r-max-kpc "$R_MAX_KPC" \
  --dr-kpc "$DR_KPC" \
  --z-max-kpc "$Z_MAX_KPC" \
  --gamma "$GAMMA" \
  "${OVERWRITE_ARGS[@]}" \
  "${PROGRESS_ARGS[@]}"

date
